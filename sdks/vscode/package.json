{
  "name": "cruxcli",
  "displayName": "CruxCLI",
  "description": "AI coding agent for your terminal — powered by CruxCLI",
  "version": "1.2.19",
  "publisher": "trinsiklabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/trinsiklabs/cruxcli"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "CruxCLI",
      "properties": {
        "cruxcli.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the cruxcli binary"
        }
      }
    },
    "commands": [
      {
        "command": "cruxcli.openTerminal",
        "title": "CruxCLI: Open",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "cruxcli.openNewTerminal",
        "title": "CruxCLI: Open in New Tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "cruxcli.addFilepathToTerminal",
        "title": "CruxCLI: Insert File Reference"
      },
      {
        "command": "cruxcli.sendSelection",
        "title": "CruxCLI: Send Selection"
      },
      {
        "command": "cruxcli.sendFile",
        "title": "CruxCLI: Send File"
      },
      {
        "command": "cruxcli.openInFolder",
        "title": "Open in CruxCLI"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cruxcli.openNewTerminal",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "cruxcli.sendSelection",
          "group": "cruxcli",
          "when": "editorHasSelection"
        },
        {
          "command": "cruxcli.sendFile",
          "group": "cruxcli"
        }
      ],
      "explorer/context": [
        {
          "command": "cruxcli.openInFolder",
          "group": "cruxcli",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cruxcli.openTerminal",
        "key": "cmd+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      },
      {
        "command": "cruxcli.openNewTerminal",
        "key": "cmd+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "cruxcli.addFilepathToTerminal",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      },
      {
        "command": "cruxcli.sendSelection",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+K",
        "linux": "ctrl+shift+K",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
