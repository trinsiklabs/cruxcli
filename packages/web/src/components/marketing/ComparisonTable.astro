---
/**
 * Comparison table for marketing pages.
 * Feature matrix comparing CruxCLI against competitors.
 */
interface Feature {
  name: string
  values: Record<string, string | boolean>
}

interface Props {
  /** Column headers (product names). First column is always "Feature". */
  products: string[]
  /** Rows of feature comparisons. */
  features: Feature[]
}

const { products, features } = Astro.props

function renderValue(value: string | boolean): string {
  if (value === true) return '\u2713'
  if (value === false) return '\u2717'
  return String(value)
}

function cellClass(value: string | boolean): string {
  if (value === true) return 'text-green-400'
  if (value === false) return 'text-dev-600'
  return 'text-dev-300'
}
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-dev-800">
        <th class="text-left py-4 px-4 text-dev-500 font-medium">Feature</th>
        {products.map((product) => (
          <th class="text-center py-4 px-4 text-dev-300 font-semibold">{product}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {features.map((feature, i) => (
        <tr class:list={['border-b border-dev-800/50', i % 2 === 0 ? 'bg-dev-900/30' : '']}>
          <td class="py-3 px-4 text-dev-400">{feature.name}</td>
          {products.map((product) => {
            const value = feature.values[product]
            return (
              <td class:list={['text-center py-3 px-4', cellClass(value ?? false)]}>
                {renderValue(value ?? false)}
              </td>
            )
          })}
        </tr>
      ))}
    </tbody>
  </table>
</div>
