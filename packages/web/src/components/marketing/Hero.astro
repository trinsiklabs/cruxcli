---
/**
 * Hero section for marketing pages.
 * Matches CruxDev pattern: tagline, description, dual CTAs.
 */
interface Props {
  tagline: string
  description: string
  primaryCta: {
    text: string
    href: string
  }
  secondaryCta?: {
    text: string
    href: string
  }
}

const { tagline, description, primaryCta, secondaryCta } = Astro.props
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-tight">
        {tagline}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-dev-400 leading-relaxed max-w-2xl mx-auto">
        {description}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={primaryCta.href}
          class="bg-accent hover:bg-accent-hover text-white px-8 py-3 rounded-lg text-base font-medium transition-colors w-full sm:w-auto text-center"
        >
          {primaryCta.text}
        </a>
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="border border-dev-700 hover:border-dev-500 text-dev-300 hover:text-white px-8 py-3 rounded-lg text-base font-medium transition-colors w-full sm:w-auto text-center"
          >
            {secondaryCta.text}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
