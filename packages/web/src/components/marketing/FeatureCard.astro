---
/**
 * Feature card for marketing pages.
 * Displays an icon, title, and description.
 */
interface Props {
  icon?: string
  title: string
  description: string
}

const { icon, title, description } = Astro.props
---

<div class="bg-dev-900 border border-dev-800 rounded-xl p-6 hover:border-dev-700 transition-colors">
  {icon && (
    <div class="text-accent text-2xl mb-4" aria-hidden="true">{icon}</div>
  )}
  <h3 class="text-lg font-semibold text-white">{title}</h3>
  <p class="mt-2 text-sm text-dev-400 leading-relaxed">{description}</p>
</div>
